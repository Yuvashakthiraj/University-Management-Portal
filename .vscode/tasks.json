{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile-java",
            "type": "shell",
            "command": "javac",
            "args": [
                "-cp",
                "lib/mysql-connector-j-8.3.0.jar",
                "-d",
                "bin",
                "src/com/university/*.java",
                "src/com/university/model/*.java",
                "src/com/university/dao/*.java",
                "src/com/university/db/*.java",
                "src/com/university/service/*.java",
                "src/com/university/ui/*.java"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$javac"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "run-gui",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                "bin;lib/mysql-connector-j-8.3.0.jar",
                "com.university.UiMain"
            ],
            "dependsOn": "compile-java",
            "options": {
                "env": {
                    "DB_PASSWORD": "yuva12@"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "run-console",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                "bin;lib/mysql-connector-j-8.3.0.jar",
                "com.university.Main"
            ],
            "dependsOn": "compile-java",
            "options": {
                "env": {
                    "DB_PASSWORD": "yuva12@"
                }
            },
            "problemMatcher": []
        }
    ]
}
